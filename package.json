{
  "name": "invictatill-browser",
  "version": "1.3.4",
  "description": "InvictaTill Browser - Ultimate Dual-Engine Gaming & Workspace Desktop Browser",
  "main": "main.js",
  "author": "InvictaTill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/invictatill-pos/invictatill-browser.git"
  },
  "scripts": {
    "start": "electron . --dev",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.invictatill.browser",
    "productName": "InvictaTill Browser",
    "publish": {
      "provider": "github",
      "owner": "invictatill-pos",
      "repo": "invictatill-browser"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "InvictaTill Browser",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
