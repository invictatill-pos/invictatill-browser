{
  "name": "invictatill-browser",
  "version": "2.1.25",
  "description": "A secure Chromium-based Windows productivity browser with private-by-default page assistance, direct InvictaTill AI integration, split view, session restore, and modern browsing tools.",
  "main": "main.js",
  "author": "InvictaTill",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/invictatill-pos/invictatill-browser.git"
  },
  "scripts": {
    "start": "electron . --dev",
    "dev": "electron . --dev",
    "check": "node scripts/check.js",
    "test": "node --test tests/*.test.js",
    "test:e2e": "node tests/electron-smoke.js",
    "verify:update-feed": "node scripts/verify-update-feed.js",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-store": "8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/fuses": "2.1.3",
    "@types/node": "^26.1.1",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "playwright-core": "1.61.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "fast-uri": "3.1.4"
  },
  "build": {
    "appId": "com.invictatill.browser",
    "productName": "InvictaTill Browser",
    "asar": true,
    "afterPack": "scripts/after-pack.js",
    "publish": {
      "provider": "github",
      "owner": "invictatill-pos",
      "repo": "invictatill-browser",
      "releaseType": "draft"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "InvictaTill Browser",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "artifactName": "InvictaTill-Browser-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "InvictaTill-Browser-Portable-${version}-${arch}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "remote-preload.js",
      "updater-controller.js",
      "focus-controller.js",
      "workspace-state.js",
      "LICENSE",
      "renderer/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
